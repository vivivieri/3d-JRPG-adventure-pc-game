{
  "version": "1.0",
  "authority": "docs/DELIVERY_CONTROL.md — pre-delivery review gate for outbound reports/artifacts. Reusable across delivery activities (telemetry reports, stakeholder reports). Gate: tools/predelivery_gate.py.",
  "policy": {
    "require_confirmation": true,
    "block_on_fail": true,
    "audit": true,
    "audit_dir": "artifacts/delivery_audit"
  },
  "channels": {
    "telegram": { "external": true, "requires_confirmation": true },
    "local": { "external": false, "requires_confirmation": false }
  },
  "deliveries": {
    "playtest_telemetry": {
      "channel": "telegram",
      "description": "Playtest telemetry summary + charts to product owner",
      "required_artifacts": ["pacing_curve.png", "deaths_by_encounter.png", "ending_funnel.png"],
      "checks": [
        { "id": "schema_valid", "type": "command", "cmd": "python3 tools/validate_playtest_telemetry_schema.py", "detail": "Telemetry schema valid" },
        { "id": "charts_present", "type": "artifacts_exist", "detail": "All required charts rendered" },
        { "id": "no_parse_errors", "type": "metric", "field": "parse_errors", "op": "==", "value": 0, "detail": "No malformed telemetry events" },
        { "id": "no_metric_fail", "type": "metric", "field": "fail_count", "op": "==", "value": 0, "severity": "block_overridable", "detail": "No hard-FAIL metrics in the report (override with --allow-metric-fail after human review)" }
      ]
    }
  }
}
