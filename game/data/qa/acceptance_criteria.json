{
  "version": "1.1",
  "authority": "Source of truth for measurable QA pass/fail. If a check is not listed here with a threshold, it cannot block ship.",
  "global_rules": {
    "warn_is_not_pass": true,
    "skip_is_not_pass": true,
    "exit_zero_with_warn_is_not_ship_pass": true,
    "jury_min_pass_models": 2,
    "jury_min_active_models": 2,
    "jury_min_confidence": 0.65,
    "remediation_required_on_fail": true,
    "evidence_required_for_pass": true,
    "agent_must_cite_criterion_id": true
  },
  "invalid_pass_patterns": [
    "F5 runs with 0 errors but no screenshot",
    "Jury skipped (no API keys) counted as PASS",
    "WARN-only technical lint counted as PASS for M5 ship",
    "overall_pass true with confidence below jury_min_confidence",
    "overall_pass true when any criterion boolean is false",
    "Re-running jury without rebuilding asset",
    "Lowering min_pass or thresholds to force green",
    "Marking phase complete with E2E script SKIP",
    "Claiming visual PASS without artifacts/screenshots evidence",
    "Procedural placeholder audio/model marked ship-ready",
    "Hand-edited ship .tscn merged without game/scenes/.gdai_built marker",
    "Treating GameLab MCP or Blender as optional for ship",
    "Merging game/development PR without green CI",
    "Skipping L6 human playtest for ship",
    "PM session without run_pm_orchestrator.sh PASS",
    "Agent work without run_agent_session_gate.sh PASS",
    "GitHub issue closed but sprint_board status not done",
    "Sprint issue pack and sprint_board ID mismatch"
  ],
  "gates": {
    "L0_rr_compliance": {
      "layer": "L0",
      "domain": "flow",
      "command": "bash tools/check_rr_compliance.sh",
      "description": "No hand-built ship .tscn; main_scene requires GDAI .gdai_built marker",
      "pass": { "exit_code": 0 },
      "evidence": ["game/scenes/.gdai_built"],
      "design_ref": ".cursorrules §0, docs/MCP_STACK.md"
    },
    "L0_story_data": {
      "layer": "L0",
      "domain": "data",
      "command": "python3 tools/validate_story_data.py",
      "description": "Story JSON cross-references are consistent",
      "pass": { "exit_code": 0, "error_count": 0 },
      "evidence": [],
      "design_ref": "docs/DATA_ARCHITECTURE.md"
    },
    "L0_acceptance_catalog": {
      "layer": "L0",
      "domain": "data",
      "command": "python3 tools/validate_acceptance_criteria.py",
      "description": "Acceptance criteria catalog schema and threshold alignment",
      "pass": { "exit_code": 0 },
      "evidence": ["game/data/qa/acceptance_criteria.json"],
      "design_ref": "docs/ACCEPTANCE_CRITERIA.md"
    },
    "L0_base_classes": {
      "layer": "L0",
      "domain": "data",
      "command": "python3 tools/validate_base_classes.py",
      "description": "Code base class registry schema (CODE_BASE_CLASS_RULES)",
      "pass": { "exit_code": 0 },
      "evidence": ["game/data/code/base_classes.json"],
      "design_ref": "docs/CODE_BASE_CLASS_RULES.md"
    },
    "L0_zone_composition": {
      "layer": "L0",
      "domain": "data",
      "command": "python3 tools/validate_zone_composition.py",
      "description": "Zone composition contract — path width, vista anchor, golden screenshot paths",
      "pass": { "exit_code": 0 },
      "evidence": ["game/data/qa/zone_composition.json"],
      "design_ref": "docs/GENERATION_READINESS.md §5"
    },
    "L0_qa_catalog": {
      "layer": "L0",
      "domain": "data",
      "command": "python3 tools/validate_qa_catalog.py",
      "description": "Model QA catalog schema; animation_timing covers required_animations",
      "pass": { "exit_code": 0 },
      "evidence": ["game/data/models/qa_catalog.json"],
      "design_ref": "docs/MODEL_QA.md, docs/GENERATION_READINESS.md §X-03"
    },
    "L0_generation_readiness_backlog": {
      "layer": "L0",
      "domain": "data",
      "command": "python3 tools/validate_generation_readiness_backlog.py",
      "description": "GR-* backlog items trace to IMPLEMENTATION_PLAN tasks and gate IDs",
      "pass": { "exit_code": 0 },
      "evidence": ["game/data/qa/generation_readiness_backlog.json"],
      "design_ref": "docs/GENERATION_READINESS.md §8, docs/IMPLEMENTATION_PLAN.md"
    },
    "L0_sprint_board": {
      "layer": "L0",
      "domain": "flow",
      "command": "python3 tools/validate_sprint_board.py --strict",
      "description": "Active sprint board — issues, deps, pack alignment; PM orchestrator source of truth",
      "pass": { "exit_code": 0 },
      "evidence": ["game/data/qa/sprint_board.json", "artifacts/pm_orchestrator_report.json"],
      "design_ref": "docs/SPRINT_ORCHESTRATION.md, docs/PM_AGENT_RUNBOOK.md"
    },
    "L0_audio_qa_catalog": {
      "layer": "L0",
      "domain": "data",
      "command": "python3 tools/validate_audio_qa_catalog.py",
      "description": "Audio QA catalog — tracks, VO clips, hero jury briefs, ACE-Step cross-ref",
      "pass": { "exit_code": 0 },
      "evidence": ["game/data/audio/audio_qa_catalog.json"],
      "design_ref": "docs/AUDIO_QA.md, docs/AUDIO_PRODUCTION_GUIDE.md"
    },
    "L0_scene_audio_map": {
      "layer": "L0",
      "domain": "data",
      "command": "python3 tools/validate_scene_audio_map.py",
      "description": "Scene/zone → BGM/ambient/sting map vs audio catalog",
      "pass": { "exit_code": 0 },
      "evidence": ["game/data/audio/scene_audio_map.json"],
      "design_ref": "docs/AUDIO_PRODUCTION_GUIDE.md §4"
    },
    "L0_base_class_compliance": {
      "layer": "L0",
      "domain": "flow",
      "command": "bash tools/check_base_class_compliance.sh",
      "description": "No rogue native extends outside registered base classes on game/development",
      "pass": { "exit_code": 0 },
      "skip_when": "game/scripts/ not present",
      "design_ref": "docs/CODE_BASE_CLASS_RULES.md"
    },
    "L1_unit_tests": {
      "layer": "L1",
      "domain": "flow",
      "command": "bash tools/run_unit_tests.sh",
      "pass": { "exit_code": 0, "failed_tests": 0 },
      "evidence": [],
      "design_ref": "docs/AI_DEV_WORKFLOW.md §3"
    },
    "L1_gdscript_lint": {
      "layer": "L1",
      "domain": "flow",
      "command": "bash tools/check_gdscript_changed.sh",
      "description": "gdlint on changed .gd files in PR diff",
      "pass": { "exit_code": 0 },
      "skip_when": "no .gd changes or no game/project.godot",
      "design_ref": "docs/CODE_STYLE.md, docs/CODE_BASE_CLASS_RULES.md"
    },
    "L2_boot_headless": {
      "layer": "L2",
      "domain": "flow",
      "command": "godot4 --headless --path game --quit-after 3",
      "description": "Main scene loads headless when run/main_scene is set (GDAI-built)",
      "pass": { "exit_code": 0 },
      "skip_when": "no run/main_scene in project.godot",
      "evidence": [],
      "design_ref": "docs/TECHNICAL_DESIGN.md"
    },
    "L2_scene_primitives": {
      "layer": "L2",
      "domain": "visual",
      "command": "bash tools/check_scene_visuals.sh",
      "pass": { "exit_code": 0, "banned_mesh_count": 0 },
      "evidence": [],
      "design_ref": "docs/VISUAL_QA.md §L1"
    },
    "L2_zone_composition": {
      "layer": "L2",
      "domain": "visual",
      "command": "bash tools/run_zone_composition_checks.sh",
      "command_ship": "ZONE_COMPOSITION_STRICT=1 bash tools/run_zone_composition_checks.sh",
      "description": "Zone scenes per zone_composition.json; golden screenshots when STRICT (GR-003)",
      "pass": { "exit_code": 0 },
      "skip_when": "no game/project.godot (main branch data-only)",
      "evidence": ["game/data/qa/zone_composition.json", "game/scenes/world/*.tscn"],
      "design_ref": "docs/GENERATION_READINESS.md §X-04, generation_readiness_backlog.json GR-003"
    },
    "L2_animation_whitelist": {
      "layer": "L2",
      "domain": "model",
      "command": "python3 tools/check_animation_whitelist.py --phase m5 --strict --check-timing",
      "description": "Rigged GLB: required ⊆ found ⊆ allowed_animations; optional duration_ms ranges",
      "pass": { "exit_code": 0 },
      "skip_when": "no rigged GLB on disk for phase (docs-only baseline)",
      "evidence": ["game/data/models/qa_catalog.json"],
      "design_ref": "docs/MODEL_QA.md §M2c, docs/CHARACTER_BIBLE.md §8"
    },
    "L2_feel_smoke": {
      "layer": "L2",
      "domain": "flow",
      "command": "bash tools/run_feel_smoke_checks.sh",
      "description": "GAME_FEEL thresholds catalog + player constant audit",
      "pass": { "exit_code": 0 },
      "skip_when": "no game/project.godot",
      "evidence": ["game/data/qa/feel_thresholds.json"],
      "design_ref": "docs/GAME_FEEL.md"
    },
    "L2_glb_import": {
      "layer": "L2",
      "domain": "model",
      "command": "python3 tools/check_glb_import_scripts.py --strict",
      "description": "Ship GLBs use glb_toon_post_import.gd",
      "pass": { "exit_code": 0 },
      "skip_when": "no GLB assets on disk",
      "evidence": ["game/scripts/editor/glb_toon_post_import.gd"],
      "design_ref": "docs/MODEL_QA.md §M2b"
    },
    "L2_visual_palette": {
      "layer": "L2",
      "domain": "visual",
      "command": "python3 tools/check_screenshot_palette.py",
      "metrics": {
        "max_avg_anchor_dist": { "op": "<=", "value": 85.0, "unit": "rgb_euclidean" },
        "max_bright_ratio": { "op": "<=", "value": 0.35, "unit": "sample_ratio" }
      },
      "evidence": ["artifacts/screenshots/phase1_{zone}_gameplay.png"],
      "design_ref": "docs/ART_DIRECTION.md §1"
    },
    "L2_model_catalog": {
      "layer": "L2",
      "domain": "model",
      "command": "python3 tools/check_model_catalog.py --phase {phase}",
      "pass": { "missing_models": 0 },
      "evidence": ["game/data/models/qa_catalog.json"],
      "design_ref": "docs/MODEL_QA.md §M1"
    },
    "L2_model_technical": {
      "layer": "L2",
      "domain": "model",
      "command": "python3 tools/check_model_technical.py",
      "metrics_source": "game/data/models/qa_catalog.json",
      "per_model": {
        "tris": { "op": "between", "from": "tris_min", "to": "tris_max" },
        "embedded_textures": { "op": ">=", "from": "texture_min" },
        "hero_min_bytes_dev": { "op": ">=", "value": 100000, "ship_only_warn": true }
      },
      "ship_extra": { "greybox_banned": true },
      "evidence": ["game/assets/models/**/*.glb"],
      "design_ref": "docs/MODEL_QA.md §M2"
    },
    "L2_audio_technical": {
      "layer": "L2",
      "domain": "audio",
      "command": "python3 tools/check_audio_technical.py",
      "metrics": {
        "sample_rate_hz": { "op": "==", "value": 44100 },
        "channels": { "op": "in", "value": [1, 2] },
        "bgm_lufs": { "op": "within", "target": -16.0, "tolerance": 4.0 },
        "bgm_true_peak_dbtp": { "op": "<=", "value": -1.0 },
        "voice_lufs": { "op": "within", "target": -18.0, "tolerance": 4.0 },
        "amb_lufs": { "op": "within", "target": -22.0, "tolerance": 4.0 }
      },
      "ship_extra": { "procedural_placeholder_banned": true },
      "evidence": ["game/assets/audio/**/*.ogg"],
      "design_ref": "docs/AUDIO_QA.md §A2"
    },
    "L2_vo_technical": {
      "layer": "L2",
      "domain": "audio",
      "command": "python3 tools/check_audio_vo.py",
      "description": "P0 VO duration, loudness, locale paths vs dialogue script",
      "metrics": {
        "max_duration_sec": { "op": "<=", "from": "audio_qa_catalog.vo_clips.*.max_duration_sec" },
        "voice_lufs": { "op": "within", "target": -18.0, "tolerance": 4.0 },
        "voice_true_peak_dbtp": { "op": "<=", "value": -3.0 }
      },
      "ship_extra": { "all_p0_locales_required": true },
      "evidence": ["game/assets/audio/voice/**/*.ogg"],
      "design_ref": "docs/AUDIO_QA.md §A4"
    },
    "L2_audio_catalog": {
      "layer": "L2",
      "domain": "audio",
      "command": "python3 tools/check_audio_catalog.py --phase {phase}",
      "pass": { "missing_tracks": 0 },
      "design_ref": "docs/AUDIO_QA.md §A1"
    },
    "L3_gdai_built": {
      "layer": "L3",
      "domain": "flow",
      "command": "bash tools/check_l3_gdai_built.sh",
      "description": "When ship scenes or main_scene change in diff, game/scenes/.gdai_built must update with verified_f5=true",
      "pass": { "exit_code": 0 },
      "skip_when": "no ship scene or main_scene changes in diff",
      "evidence": ["game/scenes/.gdai_built"],
      "design_ref": "docs/CI.md, docs/CONTROLS_CHEATSHEET.md, game/scenes/README.md"
    },
    "L3_gdai_f5": {
      "layer": "L3",
      "domain": "flow",
      "command": "GDAI MCP F5 playtest in Godot editor",
      "description": "Full viewport verify — agent-local; not GitHub Actions",
      "pass": { "verified_f5": true, "editor_errors": 0 },
      "evidence": ["game/scenes/.gdai_built"],
      "design_ref": "docs/MCP_STACK.md, .cursorrules §0"
    },
    "L4_integration": {
      "layer": "L4",
      "domain": "flow",
      "command": "bash tools/run_integration_tests.sh",
      "pass": { "exit_code": 0, "failed_scenarios": 0 },
      "evidence": ["game/tests/integration/"],
      "design_ref": "docs/AI_TESTING_SPEC.md §6"
    },
    "L5_e2e_three_endings": {
      "layer": "L5",
      "domain": "flow",
      "command": "REQUIRE_L5=1 bash tools/run_e2e_playthrough.sh",
      "pass": { "exit_code": 0, "skip_allowed": false, "endings_passed": ["rewind", "anchor", "drift"] },
      "evidence": ["artifacts/videos/e2e_*.mp4"],
      "design_ref": "docs/AI_TESTING_SPEC.md §7"
    },
    "L6_human_playtest": {
      "layer": "L6",
      "domain": "flow",
      "command": "docs/PLAYTEST_SCRIPT.md",
      "pass": { "completion_percent": 80, "s0_s1_open": 0, "min_testers": 5 },
      "prerequisite": ["L0", "L1", "L2", "L3", "L4", "L5"],
      "design_ref": "docs/PLAYTEST_SCRIPT.md"
    },
    "M5_asset_compliance": {
      "layer": "ship",
      "domain": "compliance",
      "command": "bash tools/check_asset_compliance.sh",
      "pass": { "exit_code": 0 },
      "design_ref": "docs/ASSET_COMPLIANCE.md"
    }
  },
  "jury": {
    "visual": {
      "gate_id": "L2_visual_jury",
      "min_pass_models": 2,
      "min_active_models": 2,
      "min_confidence": 0.65,
      "require_issues_on_fail": true,
      "criteria": {
        "v1_primitives_visible": { "expect": false, "label": "No obvious axis-aligned box primitives" },
        "v2_muted_palette": { "expect": true, "label": "Muted coastal palette" },
        "v3_npr_not_pbr": { "expect": true, "label": "Stylized NPR not glossy PBR" },
        "v4_japanese_coastal": { "expect": true, "label": "Japanese coastal motifs" },
        "v5_silhouette_readable": { "expect": true, "label": "Readable silhouettes" },
        "v6_ui_clean": { "expect": true, "label": "UI clean if visible" },
        "v7_emotional_mood_matches": { "expect": true, "label": "Zone emotional mood matches brief" },
        "v8_no_forbidden_tone": { "expect": true, "label": "No forbidden tone (comedy/horror gore/bright cheer)" }
      },
      "evidence": ["artifacts/screenshots/*.png", "artifacts/visual_reviews/*.jury.json"],
      "design_ref": "docs/VISUAL_QA.md §2G"
    },
    "model": {
      "gate_id": "L2_model_jury",
      "min_pass_models": 2,
      "min_active_models": 2,
      "min_confidence": 0.65,
      "require_issues_on_fail": true,
      "criteria": {
        "m1_not_block_primitive": { "expect": true, "label": "Not block primitive" },
        "m2_japanese_coastal_style": { "expect": true, "label": "Japanese coastal style" },
        "m3_adult_not_chibi": { "expect": true, "label": "Adult proportions not chibi" },
        "m4_silhouette_readable": { "expect": true, "label": "Silhouette readable" },
        "m5_sufficient_detail": { "expect": true, "label": "Sufficient NPR detail" },
        "m6_matches_brief": { "expect": true, "label": "Matches CHARACTER_BIBLE brief" },
        "m7_emotional_mood_matches": { "expect": true, "label": "Emotional mood matches generation brief" },
        "m8_no_forbidden_tone": { "expect": true, "label": "No forbidden tone (comedy/horror gore/bright cheer)" }
      },
      "evidence": ["artifacts/model_reviews/*/front.png", "artifacts/model_reviews/*.model_jury.json"],
      "design_ref": "docs/MODEL_QA.md §M3b"
    },
    "audio": {
      "gate_id": "L2_audio_jury",
      "min_pass_models": 2,
      "min_active_models": 2,
      "min_confidence": 0.65,
      "require_issues_on_fail": true,
      "hero_tracks_only": true,
      "criteria": {
        "a1_not_cheap_procedural": { "expect": true, "label": "Not cheap procedural placeholder" },
        "a2_melancholy_coastal": { "expect": true, "label": "Melancholy coastal mood" },
        "a3_not_upbeat_pop": { "expect": true, "label": "Not upbeat pop/EDM" },
        "a4_instrumental_no_vocals": { "expect": true, "label": "Instrumental no vocals" },
        "a5_fits_scene_mood": { "expect": true, "label": "Fits scene mood" },
        "a6_emotional_mood_matches": { "expect": true, "label": "Emotional mood matches generation brief" },
        "a7_no_forbidden_tone": { "expect": true, "label": "No forbidden tone (comedy/horror gore/bright cheer/EDM)" }
      },
      "evidence": ["artifacts/audio_reviews/*.jury.json"],
      "design_ref": "docs/AUDIO_QA.md §A3"
    },
    "vo": {
      "gate_id": "L2_vo_jury",
      "min_pass_models": 2,
      "min_active_models": 2,
      "min_confidence": 0.65,
      "require_issues_on_fail": true,
      "p0_clips_only": true,
      "gate_locale": "en",
      "criteria": {
        "v1_not_robotic_placeholder": { "expect": true, "label": "Not robotic TTS placeholder" },
        "v2_script_semantics_match": { "expect": true, "label": "Script semantics match dialogue" },
        "v3_matches_direction": { "expect": true, "label": "Matches vo_prompts direction" },
        "v4_not_anime_exaggeration": { "expect": true, "label": "Not anime exaggeration" },
        "v5_fits_scene_mood": { "expect": true, "label": "Fits scene mood" },
        "v6_emotional_mood_matches": { "expect": true, "label": "Emotional mood matches generation brief" },
        "v7_no_forbidden_tone": { "expect": true, "label": "No forbidden tone from brief" }
      },
      "evidence": ["artifacts/vo_reviews/*.jury.json"],
      "design_ref": "docs/AUDIO_QA.md §A5"
    }
  },
  "docs_ci_gates": {
    "branch": "main",
    "workflow": ".github/workflows/ci.yml",
    "runner": "bash tools/run_docs_ci_checks.sh",
    "required_gates": [
      "L0_story_data",
      "L0_acceptance_catalog",
      "L0_environments_catalog",
      "L0_sprint_phases",
      "L0_base_classes",
      "L0_zone_composition",
      "L0_qa_catalog",
      "L0_audio_qa_catalog",
      "L0_scene_audio_map",
      "L0_generation_readiness_backlog",
      "L0_sprint_board",
      "L0_rr_compliance",
      "M5_asset_compliance"
    ],
    "design_ref": "docs/BRANCHING.md"
  },
  "ci_gates": {
    "branch": "game/development",
    "workflow": ".github/workflows/game-ci.yml",
    "runner": "bash tools/run_ci_checks.sh",
    "required_gates": [
      "L0_rr_compliance",
      "L0_story_data",
      "L0_acceptance_catalog",
      "L0_base_classes",
      "L1_unit_tests",
      "L1_gdscript_lint",
      "L0_base_class_compliance",
      "L2_scene_primitives",
      "L3_gdai_built",
      "L2_animation_whitelist",
      "L2_feel_smoke",
      "L2_glb_import",
      "L4_integration",
      "M5_asset_compliance"
    ],
    "conditional_gates": [
      {
        "gate_id": "L2_boot_headless",
        "skip_when": "no run/main_scene in project.godot",
        "skip_is_not_ship_pass": true
      }
    ],
    "excluded_gates": [
      "check_mcp_ready",
      "L3_gdai_f5",
      "L2_visual_jury",
      "L2_model_jury",
      "L2_audio_jury",
      "L2_vo_jury",
      "L5_e2e_three_endings",
      "L6_human_playtest"
    ],
    "design_ref": "docs/CI.md, .cursorrules §0, docs/AI_DEV_WORKFLOW.md §2",
    "merge_policy": "game/development PRs require CI green — fails until project.godot + tests bootstrap; not deferrable"
  },
  "toolchain_requirements": {
    "required_not_optional": [
      {
        "id": "gamelab_mcp",
        "check": "gamelab-mcp in Cursor + GAMELAB_API_KEY",
        "command": "bash tools/check_extended_toolchain.sh",
        "asset_fallback": "Procedural UI placeholders OK for asset output until GameLab gen ships"
      },
      {
        "id": "blender",
        "check": "blender in PATH",
        "purpose": "M5 turntable QA — docs/MODEL_QA.md M3",
        "command": "bash tools/check_extended_toolchain.sh"
      },
      {
        "id": "game_development_ci",
        "check": "bash tools/run_ci_checks.sh exit 0",
        "note": "Required merge gate on game/development — expected to fail until bootstrap"
      },
      {
        "id": "l6_human_playtest",
        "gate_id": "L6_human_playtest",
        "when": "Phase 8 prod CD after L0–L5",
        "note": "Required ship gate — not optional"
      }
    ],
    "design_ref": "docs/MCP_STACK.md, docs/ART_AUTOMATION_PIPELINE.md §2, docs/CI.md"
  },
  "cd_gates": {
    "branch": "game/development",
    "artifact_workflow": ".github/workflows/cd-artifact.yml",
    "steam_workflow": ".github/workflows/cd-steam.yml",
    "runner": "bash tools/run_cd_gates.sh",
    "tag_patterns": ["v*-rc*", "v*-beta*", "v*.*.*"],
    "channels": {
      "rc": { "l5_required": false, "github_release": true },
      "beta": { "l5_required": true, "steam_upload": true },
      "prod": { "l5_required": true, "l6_required": true, "steam_upload": true, "manual_approval": true }
    },
