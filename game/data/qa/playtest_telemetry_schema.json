{
  "version": "1.0",
  "authority": "Schema + thresholds for dev-time playtest telemetry (Games User Research tuning loop). Analyzer: tools/analyze_playtest_telemetry.py. Informational QA input feeding docs/FLOW_QA.md + docs/QA_REMEDIATION_LOOP.md — NOT a ship gate (a red metric opens a remediation item, it does not by itself block ship).",
  "design_ref": "docs/PLAYTEST_TELEMETRY.md, docs/PACING_CHART.md, docs/FLOW_QA.md, docs/ACCEPTANCE_CRITERIA.md",
  "privacy": {
    "local_only_by_default": true,
    "pii_forbidden": true,
    "forbidden_fields": ["player_name", "email", "ip", "geo", "machine_id"],
    "run_id_rule": "opaque random UUID generated per run — never tied to a real identity",
    "upload_requires_consent": true,
    "design_ref": "docs/PLAYTEST_TELEMETRY.md#privacy"
  },
  "log_format": {
    "encoding": "jsonl",
    "one_object_per_line": true,
    "common_fields": {
      "run_id": "string — opaque per-run id (groups events of one playthrough)",
      "event": "string — must be one of event_types[].name",
      "t": "number — seconds since session_start (monotonic)",
      "ts": "string (optional) — ISO-8601 wall-clock for reference"
    }
  },
  "event_types": [
    { "name": "session_start", "required": ["run_id", "event", "t"], "optional": ["build", "locale"] },
    { "name": "session_end", "required": ["run_id", "event", "t"], "optional": ["reason"], "enums": { "reason": ["quit", "completed", "crash"] } },
    { "name": "scene_beat", "required": ["run_id", "event", "t", "scene"], "note": "scene must match scene_beats[].id" },
    { "name": "zone_enter", "required": ["run_id", "event", "t", "zone"], "enums": { "zone": ["ruined_village", "beach_shore", "tidal_caves", "dragon_palace_gate"] } },
    { "name": "zone_exit", "required": ["run_id", "event", "t", "zone"] },
    { "name": "combat_start", "required": ["run_id", "event", "t", "encounter"] },
    { "name": "combat_end", "required": ["run_id", "event", "t", "encounter", "result"], "optional": ["turns", "duration_s", "max_turn_resolve_s"], "enums": { "result": ["win", "lose", "flee"] } },
    { "name": "player_death", "required": ["run_id", "event", "t"], "optional": ["encounter", "zone"] },
    { "name": "choice_made", "required": ["run_id", "event", "t", "choice_id", "option"] },
    { "name": "puzzle_start", "required": ["run_id", "event", "t", "puzzle_id"] },
    { "name": "puzzle_solved", "required": ["run_id", "event", "t", "puzzle_id"], "optional": ["duration_s", "hints_used"] },
    { "name": "ending_reached", "required": ["run_id", "event", "t", "ending"], "enums": { "ending": ["rewind", "anchor", "drift"] } },
    { "name": "progress", "required": ["run_id", "event", "t"], "optional": ["note"], "note": "generic progress marker; resets the stuck timer" }
  ],
  "progress_events": ["scene_beat", "zone_enter", "zone_exit", "combat_start", "combat_end", "choice_made", "puzzle_start", "puzzle_solved", "ending_reached", "progress"],
  "thresholds": {
    "completion_rate_min_percent": { "value": 80, "op": ">=", "gate_ref": "L6_human_playtest.completion_percent", "design_ref": "docs/ACCEPTANCE_CRITERIA.md" },
    "target_playtime_minutes": { "value": 150, "tolerance": 45, "design_ref": "docs/PACING_CHART.md" },
    "stuck_seconds": { "value": 300, "op": ">", "note": "no progress event for longer than this = stuck/confusion hotspot", "design_ref": "docs/FLOW_QA.md" },
    "combat_turn_resolve_max_s": { "value": 3.0, "op": "<=", "feel_ref": "feel_combat_turn_max", "design_ref": "docs/GAME_FEEL.md" },
    "encounter_avg_deaths_flag": { "value": 3.0, "op": "<=", "note": "avg deaths/session for an encounter above this = difficulty spike", "design_ref": "docs/COMBAT_SYSTEMS.md" },
    "no_combat_before_scene": { "value": "SC-05", "note": "PACING rule — no combat before SC-05 (~22 min)", "design_ref": "docs/PACING_CHART.md" },
    "scene_beat_drift_tolerance_min": { "value": 12, "note": "arrival time drift vs scene_beats target before flagging pacing", "design_ref": "docs/PACING_CHART.md" },
    "endings_required_coverage": { "value": ["rewind", "anchor", "drift"], "op": "all_present_across_runs", "gate_ref": "L5_e2e_three_endings", "design_ref": "docs/ENDING_DESIGN.md" }
  },
  "scene_beats": [
    { "id": "SC-00", "target_min": 0, "label": "Prologue" },
    { "id": "SC-01", "target_min": 2, "label": "Movement teach" },
    { "id": "SC-02", "target_min": 8, "label": "Ruined village dread" },
    { "id": "SC-03", "target_min": 12, "label": "Yuzu voice" },
    { "id": "SC-04", "target_min": 18, "label": "Roku anchor" },
    { "id": "SC-05", "target_min": 22, "label": "First fight (combat unlocks)" },
    { "id": "SC-06", "target_min": 28, "label": "Dungeon enter" },
    { "id": "SC-07", "target_min": 35, "label": "Puzzle breather" },
    { "id": "SC-08", "target_min": 42, "label": "Wraith pair" },
    { "id": "SC-09", "target_min": 50, "label": "Solo boss peak" },
    { "id": "SC-10", "target_min": 58, "label": "Yuzu join" },
    { "id": "SC-11", "target_min": 65, "label": "Flashback" },
    { "id": "SC-12", "target_min": 72, "label": "Palace wraiths gate" },
    { "id": "SC-13", "target_min": 82, "label": "Box truth" },
    { "id": "SC-14", "target_min": 92, "label": "Miniboss" },
    { "id": "SC-15", "target_min": 105, "label": "Final boss" },
    { "id": "SC-16", "target_min": 115, "label": "Choice" },
    { "id": "SC-17", "target_min": 120, "label": "Ending / credits" }
  ]
}
