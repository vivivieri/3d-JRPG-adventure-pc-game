{
  "schema_version": 1,
  "design_ref": "docs/ui/UI_UX_FLOW.md §10–11, docs/gameplay/PLAYER_CONTROLS.md",
  "note": "Machine-readable InputMap contract — GDAI MCP applies to project.godot at P1-02+.",
  "actions": [
    {
      "id": "move_left",
      "keyboard": ["A"],
      "gamepad": ["Joypad Motion Left x-"],
      "deadzone": 0.2
    },
    {
      "id": "move_right",
      "keyboard": ["D"],
      "gamepad": ["Joypad Motion Left x+"]
    },
    {
      "id": "move_forward",
      "keyboard": ["W"],
      "gamepad": ["Joypad Motion Left y-"]
    },
    {
      "id": "move_back",
      "keyboard": ["S"],
      "gamepad": ["Joypad Motion Left y+"]
    },
    {
      "id": "interact",
      "keyboard": ["E"],
      "gamepad": ["Joypad Button 0"]
    },
    {
      "id": "open_menu",
      "keyboard": ["Tab"],
      "gamepad": ["Joypad Button 3"]
    },
    {
      "id": "pause",
      "keyboard": ["Escape"],
      "gamepad": ["Joypad Button 6"]
    },
    {
      "id": "camera_orbit",
      "mouse": ["Mouse Button Right"],
      "gamepad": ["Joypad Motion Right"]
    },
    {
      "id": "camera_zoom_in",
      "mouse": ["Mouse Wheel Up"]
    },
    {
      "id": "camera_zoom_out",
      "mouse": ["Mouse Wheel Down"]
    },
    {
      "id": "dialogue_advance",
      "keyboard": ["Space", "Enter", "E"],
      "gamepad": ["Joypad Button 0"]
    },
    {
      "id": "skip_hold",
      "keyboard": ["Space", "Enter"],
      "gamepad": ["Joypad Button 0"],
      "hold_sec": 1.0,
      "context": "prologue_cinematic_skip"
    }
  ],
  "built_in_ui": ["ui_accept", "ui_cancel", "ui_up", "ui_down", "ui_left", "ui_right"]
}
