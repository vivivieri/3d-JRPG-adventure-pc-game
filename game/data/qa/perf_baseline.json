  "baselines": {
    "reference_linux_cloud": {
      "label": "Reference Linux — cloud dev + Linux Steam ship",
      "valid_for_l3_perf_review": true,
      "valid_for_ship_signoff": true,
      "platform": "linux",
      "os": {
        "name": "Linux",
        "distro_min": "Ubuntu 22.04 LTS x86_64",
        "distro_recommended": "Ubuntu 24.04 LTS x86_64"
      },
      "cpu": {
        "class": "mid-tier cloud/desktop",
        "example_models": ["Intel Xeon (cloud)", "AMD Ryzen 5 3600"],
        "cores_threads": "4C/8T+",
        "base_clock_ghz_min": 2.4
      },
      "memory_gb": {
        "min": 8,
        "recommended": 16
      },
      "gpu": {
        "class": "GTX 1060 equivalent (Vulkan)",
        "example_models": ["NVIDIA T4 / GTX 1060 (Mesa or proprietary)"],
        "vram_gb_min": 6,
        "api": ["Vulkan 1.0", "OpenGL 3.3"]
      },
      "display": {
        "resolution": "1920x1080",
        "fullscreen": true,
        "vsync": false,
        "dpi_scale": 100
      },
      "godot": {
        "version": "4.7",
        "renderer": "Forward+",
        "graphics_quality": "medium",
        "msaa": "2x",
        "shadows": "soft_1024",
        "glow": true,
        "fog_density_scale": 1.0,
        "ssao_ssil": false,
        "editor_perf_note": "Cursor Cloud snapshot boot required — JIT VMs use cloud_agent_jit (invalid)"
      },
      "fps_targets": {
        "gameplay_min": 60,
        "editor_viewport_min": 55,
        "investigate_below": 30
      },
      "requires_snapshot_boot": true,
      "notes": "Primary dev + Linux depot perf. Cloud agents MUST use game/development snapshot."
    },
    "reference_pc_gtx1060": {
      "label": "Reference PC — ship perf sign-off",
      "valid_for_l3_perf_review": true,
      "valid_for_ship_signoff": true,
      "platform": "windows",
      "os": {
        "name": "Windows",
        "version_min": "10 64-bit",
        "version_recommended": "11 64-bit"
      },
      "cpu": {
        "class": "mid-tier desktop",
        "example_models": ["Intel Core i5-8400", "AMD Ryzen 5 2600"],
