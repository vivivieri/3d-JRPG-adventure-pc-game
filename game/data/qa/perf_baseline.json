{
  "version": "1.1",
  "authority": "docs/PERFORMANCE_BASELINE.md, docs/PLATFORM_SUPPORT.md",
  "design_ref": "docs/RENDERING_GUIDE.md, docs/ENVIRONMENT_KITS.md §9, steam/STORE_PAGE.md",
  "primary_baseline_id": "reference_linux_cloud",
