        "base_clock_ghz_min": 2.8
      },
      "memory_gb": {
        "min": 8,
        "recommended": 16
      },
      "gpu": {
        "class": "GTX 1060 equivalent",
        "example_models": ["NVIDIA GeForce GTX 1060 6GB", "AMD RX 580 8GB"],
        "vram_gb_min": 6,
        "api": ["Vulkan 1.0", "OpenGL 3.3"]
      },
      "display": {
        "resolution": "1920x1080",
        "fullscreen": true,
        "vsync": false,
        "dpi_scale": 100
      },
      "godot": {
        "version": "4.7",
        "renderer": "Forward+",
        "graphics_quality": "medium",
        "msaa": "2x",
        "shadows": "soft_1024",
        "glow": true,
        "fog_density_scale": 1.0,
        "ssao_ssil": false,
        "editor_perf_note": "Editor F5 may read 55–60 FPS; exported build is authoritative for ship"
