      },
      {
        "id": "game_development_ci",
        "check": "bash tools/run_ci_checks.sh exit 0",
        "note": "Required merge gate on game/development — use run_bootstrap_ci_checks.sh during P1-00; full run_ci_checks.sh after P1-02 main_scene"
      },
      {
        "id": "l6_human_playtest",
        "gate_id": "L6_human_playtest",
        "when": "Phase 8 prod CD after L0–L5",
        "note": "Required ship gate — not optional"
      }
    ],
    "design_ref": "docs/agents/MCP_STACK.md, docs/art/ART_AUTOMATION_PIPELINE.md §2, docs/ci-cd/CI.md"
  },
