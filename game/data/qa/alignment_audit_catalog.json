      "audit_radar_report.png",
      "audit_radar_spec.png",
      "audit_radar_spec_breakdown.png",
      "audit_radar_spec_data_alignment.png",
      "audit_radar_spec_narrative.png",
      "audit_radar_spec_gameplay.png",
      "audit_radar_spec_visual_spec.png",
      "audit_radar_spec_ux_controls.png",
      "audit_radar_spec_pm_workflow.png",
      "audit_radar_build.png",
      "audit_radar_build_breakdown.png",
      "audit_radar_build_runtime_proof.png",
