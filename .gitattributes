# Git LFS — large binary game assets (M5+). See docs/ci-cd/GIT_LFS.md
*.glb filter=lfs diff=lfs merge=lfs -text
*.gltf filter=lfs diff=lfs merge=lfs -text
*.blend filter=lfs diff=lfs merge=lfs -text
*.fbx filter=lfs diff=lfs merge=lfs -text
*.wav filter=lfs diff=lfs merge=lfs -text
game/assets/**/*.png filter=lfs diff=lfs merge=lfs -text
game/assets/**/*.webp filter=lfs diff=lfs merge=lfs -text
game/assets/**/*.jpg filter=lfs diff=lfs merge=lfs -text
game/assets/**/*.jpeg filter=lfs diff=lfs merge=lfs -text
game/assets/audio/**/*.ogg filter=lfs diff=lfs merge=lfs -text
