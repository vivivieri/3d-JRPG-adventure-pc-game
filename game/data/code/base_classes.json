{
  "version": "1.1",
  "authority": "docs/technical/CODE_BASE_CLASS_RULES.md — agents extend these GDScript bases; they do not rewrite core stacks",
  "note": "This is CODE inheritance (GDScript classes), not 3D mesh 'base models'. See §3 in CODE_BASE_CLASS_RULES.md for asset licenses.",
  "architect_owns": [
    "res://scripts/autoload/",
    "res://scripts/combat/",
    "res://scripts/exploration/player_controller.gd",
    "res://scripts/exploration/interactable.gd",
    "res://scripts/exploration/zone_transition.gd",
    "res://scripts/exploration/encounter_trigger.gd",
    "res://scripts/exploration/zone_visuals.gd"
  ],
  "bases": [
    {
      "id": "EventBus",
      "path": "res://scripts/core/event_bus.gd",
      "extends": "Node",
      "phase": 1,
      "agent_rule": "architect_only",
      "description": "Autoload — global typed signals only (helpers_registry.json)"
    },
    {
      "id": "GameBootstrap",
      "path": "res://scripts/core/game_bootstrap.gd",
      "extends": "Node",
      "phase": 0,
      "agent_rule": "architect_only",
      "description": "Autoload — startup JSON path validation (autoload_registry.json)"
    },
    {
      "id": "PlayerController",
      "path": "res://scripts/exploration/player_controller.gd",
      "extends": "CharacterBody3D",
      "phase": 2,
      "agent_rule": "extend_only",
      "description": "Field movement, interaction ray — single player implementation"
    },
    {
      "id": "Combatant",
      "path": "res://scripts/combat/combatant.gd",
      "extends": "Node",
      "phase": 4,
      "agent_rule": "extend_only",
      "description": "Battle actor HP/MP/status — PlayerCombatant / EnemyCombatant subclasses"
    },
    {
      "id": "Interactable",
      "path": "res://scripts/exploration/interactable.gd",
      "extends": "Area3D",
      "phase": 3,
      "agent_rule": "extend_only",
      "description": "Inspectables, NPC dialogue hooks — scene instances only",
      "exports": [
        { "name": "scene_id", "type": "String", "default": "" },
        { "name": "interaction_prompt", "type": "String", "default": "Interact" }
      ],
      "public_api": [
        {
          "name": "interact",
          "args": ["player: PlayerController"],
          "returns": "void",
          "note": "Calls DialogueRunner.start(scene_id) when scene_id set; else inspect flow"
        },
        {
          "name": "can_interact",
          "args": [],
          "returns": "bool",
          "note": "False when requires_flags/requires_items not met"
        }
      ]
    },
    {
      "id": "SavePoint",
      "path": "res://scripts/exploration/save_point.gd",
      "extends": "Interactable",
      "phase": 3,
      "agent_rule": "extend_only",
      "description": "Well / save shrine — extends Interactable with autosave hook"
    },
    {
      "id": "ZoneTransition",
      "path": "res://scripts/exploration/zone_transition.gd",
      "extends": "Area3D",
      "phase": 3,
      "agent_rule": "extend_only",
      "description": "Zone loads with spawn marker",
      "exports": [
        { "name": "target_zone", "type": "String", "default": "" },
        { "name": "spawn_marker", "type": "String", "default": "SpawnMarker_default" },
        { "name": "requires_flags", "type": "Array[String]", "default": [] }
      ],
      "public_api": [
        {
          "name": "try_transition",
          "args": ["body: Node3D"],
          "returns": "void",
          "note": "When player enters and flags pass, GameManager.change_zone(target_zone, spawn_marker)"
        }
      ]
    },
    {
      "id": "EncounterTrigger",
      "path": "res://scripts/exploration/encounter_trigger.gd",
      "extends": "Area3D",
      "phase": 4,
      "agent_rule": "extend_only",
      "description": "Starts encounter from story_encounters.json",
      "exports": [
        { "name": "encounter_id", "type": "String", "default": "" },
        { "name": "one_shot", "type": "bool", "default": true }
      ],
      "public_api": [
        {
          "name": "try_encounter",
          "args": ["body: Node3D"],
          "returns": "void",
          "note": "CombatManager.start_encounter(encounter_id) when conditions met"
        },
        {
          "name": "can_trigger",
          "args": [],
          "returns": "bool",
          "note": "Checks story_encounters.json requires_flags and one_shot state"
        }
      ]
    },
    {
      "id": "BootLoader",
      "path": "res://scripts/core/boot_loader.gd",
      "extends": "Node",
      "phase": 2,
      "agent_rule": "architect_only",
      "description": "Boot scene entry — validate data paths then load main_menu",
      "public_api": [
        {
          "name": "run_boot",
          "args": [],
          "returns": "void",
          "note": "GameBootstrap.validate_data_paths(); change_scene_to_file(main_menu) on success"
        },
        {
          "name": "get_boot_errors",
          "args": [],
          "returns": "PackedStringArray",
          "note": "Delegates to GameBootstrap.get_boot_errors()"
        }
      ]
    },
    {
      "id": "CombatManager",
      "path": "res://scripts/autoload/combat_manager.gd",
      "extends": "Node",
      "phase": 4,
      "agent_rule": "architect_only",
      "description": "Autoload — agents wire scenes; do not fork combat math"
    },
    {
      "id": "TurnManager",
      "path": "res://scripts/combat/turn_manager.gd",
      "extends": "Node",
      "phase": 4,
      "agent_rule": "architect_only",
      "description": "SPD sort, round tick — state machine owned by Architect"
    },
    {
      "id": "ZoneVisuals",
      "path": "res://scripts/exploration/zone_visuals.gd",
      "extends": "Node3D",
      "phase": 1,
      "agent_rule": "architect_only",
      "class_name": "ZoneVisuals",
      "description": "Per-zone palette, sky, fog, and WorldEnvironment preset application",
      "python_reference": "tools/zone_visuals_lib.py",
      "data_ref": [
        "game/data/world/zone_palettes.json",
        "game/data/code/environment_registry.json"
      ],
      "design_ref": [
        "docs/art/RENDERING_GUIDE.md §13",
        "docs/art/SHADER_SPECS.md",
        "docs/sprints/Phase1-Sprint1-issues.md §P1-01"
      ],
      "exports": [
        { "name": "zone_id", "type": "String", "default": "ruined_village" },
        { "name": "apply_on_ready", "type": "bool", "default": true }
      ],
      "public_api": [
        {
          "name": "apply_to_scene",
          "args": ["zone_id: String"],
          "returns": "Dictionary",
          "static": true,
          "note": "Canonical zone entry — returns environment, directional, fill_light, node_names bundle for Builder wiring"
        },
        {
          "name": "directional_settings",
          "args": ["zone_key: String"],
          "returns": "Dictionary",
          "static": true,
          "note": "DirectionalLight3D color, shadow, rotation from palette row"
        },
        {
          "name": "fill_light_settings",
          "args": ["zone_key: String"],
          "returns": "Dictionary",
          "static": true,
          "note": "OmniLight3D fill color, energy, range from palette row + defaults"
        },
        {
          "name": "apply_zone_visuals",
          "args": [
            "world_environment: WorldEnvironment = null",
            "directional: DirectionalLight3D = null",
            "fill_lights: Array[OmniLight3D] = []"
          ],
          "returns": "void",
          "static": false,
          "note": "Instance method; uses export zone_id and res://data/world/zone_palettes.json"
        },
        {
          "name": "build_environment",
          "args": ["preset: Dictionary"],
          "returns": "Environment",
          "note": "Builds Environment from palette row + catalog defaults"
        },
        {
          "name": "hex_to_color",
          "args": ["hex: String"],
          "returns": "Color",
          "static": true
        },
        {
          "name": "get_preset",
          "args": ["zone_key: String", "presets: Dictionary"],
          "returns": "Dictionary",
          "static": true
        }
      ],
      "lifecycle": [
        { "signal": "_ready", "when": "apply_on_ready", "calls": "apply_zone_visuals()" }
      ],
      "constants": [
        { "name": "PALETTE_PATH", "value": "res://data/world/zone_palettes.json" }
      ]
    }
  ],
  "component_scenes": [
    {
      "id": "interactable_inspect",
      "path": "res://scenes/components/interactable_inspect.tscn",
      "script": "Interactable",
      "phase": 3
    },
    {
      "id": "zone_transition",
      "path": "res://scenes/components/zone_transition.tscn",
      "script": "ZoneTransition",
      "phase": 3
    },
    {
      "id": "encounter_trigger",
      "path": "res://scenes/components/encounter_trigger.tscn",
      "script": "EncounterTrigger",
      "phase": 4
    },
    {
      "id": "save_point",
      "path": "res://scenes/components/save_point.tscn",
      "script": "SavePoint",
      "phase": 3
    },
    {
      "id": "lantern_fill",
      "path": "res://scenes/components/lantern_fill.tscn",
      "script": null,
      "phase": 1,
      "note": "OmniLight3D + mesh instance — palette from ENVIRONMENT_KITS"
    }
  ],
  "forbidden": [
    "extends CharacterBody3D in zone .tscn root for player (use PlayerController scene)",
    "new combat damage formulas in scene scripts (use SkillResolver + game/data/skills.json)",
    "duplicate InputMap actions (UI_UX_FLOW.md canonical names only)",
    "free-form AI state machine replacing TurnManager without Architect PR"
  ],
  "design_ref": "docs/technical/TECHNICAL_DESIGN.md, docs/technical/CODE_BASE_CLASS_RULES.md"
}
