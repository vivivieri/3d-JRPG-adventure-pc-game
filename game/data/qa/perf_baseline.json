      "memory_gb": { "min": 4, "recommended": 8 },
      "gpu": {
        "class": "OpenGL 3.3 / Vulkan 1.0 compatible",
        "vram_gb_min": 2,
        "api": ["Vulkan 1.0", "OpenGL 3.3"]
      },
      "display": {
        "resolution": "1280x720",
        "fullscreen": false,
        "vsync": true,
        "graphics_quality": "low"
