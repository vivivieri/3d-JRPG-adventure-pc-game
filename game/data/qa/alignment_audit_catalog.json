  "verdict_thresholds": {
    "aligned_min_overall": 8.0,
    "aligned_max_blocking": 0,
    "at_risk_min_overall": 6.5,
    "fail_any_ci": true,
    "build_aligned_min": 6.0,
    "build_at_risk_min": 4.0
  },
  "streams": {
    "spec_readiness": {
      "id": "spec_readiness",
      "label": "Design & Preparation",
      "short_label": "Spec",
      "question": "Can we dispatch builders? Is design truth complete?",
      "domains": [
        "data_alignment",
        "narrative",
        "gameplay",
        "visual_spec",
        "ux_controls",
        "pm_workflow"
      ],
      "primary_on_branches": ["main"],
      "not_applicable_on_branches": [],
      "na_reason": null
    },
    "build_readiness": {
      "id": "build_readiness",
      "label": "Development & Shipping",
      "short_label": "Build",
      "question": "Does the game run, pass gates, and approach Steam?",
      "domains": ["runtime_proof", "steam_ship"],
      "primary_on_branches": ["game/development"],
      "applicable_on_branches": ["game/development"],
      "not_applicable_on_branches": ["main"],
      "na_reason": "Build stream applies only on game/development — main holds specs until P1-00 bootstrap"
    }
  },
  "domains": [
    {
      "id": "overall_production",
      "label": "Overall Spec (legacy alias)",
      "weight": 1.0,
      "derive": "mean_stream",
      "stream": "spec_readiness",
      "icon": "overall",
      "hidden_from_dashboard": true
    },
    {
      "id": "data_alignment",
      "label": "Data Alignment",
      "weight": 1.0,
      "signals": [
        { "id": "scene_registry_parity", "weight": 0.22, "kind": "parity" },
        { "id": "hooks_parity", "weight": 0.18, "kind": "parity" },
        { "id": "tutorial_flags", "weight": 0.13, "kind": "parity" },
        { "id": "sprint_board_parity", "weight": 0.15, "kind": "parity" },
        { "id": "L0_scene_registry", "weight": 0.17, "kind": "gate" },
        { "id": "L0_story_data", "weight": 0.15, "kind": "gate" }
      ],
      "icon": "data"
    },
    {
      "id": "narrative",
      "label": "Narrative",
      "weight": 1.0,
      "signals": [
        { "id": "L0_story_data", "weight": 0.35, "kind": "gate" },
        { "id": "L0_narrative_density", "weight": 0.25, "kind": "gate" },
        { "id": "vo_hit_list", "weight": 0.2, "kind": "metric", "target": 12 },
        { "id": "cinematic_hooks", "weight": 0.2, "kind": "metric", "target": 6 }
      ],
      "icon": "narrative"
    },
    {
      "id": "gameplay",
      "label": "Gameplay",
      "weight": 1.0,
      "signals": [
        { "id": "L0_spec_registry", "weight": 0.3, "kind": "gate" },
        { "id": "encounters_catalogued", "weight": 0.25, "kind": "metric", "target": 9 },
        { "id": "L0_difficulty_data", "weight": 0.2, "kind": "gate" },
        { "id": "L0_base_classes", "weight": 0.25, "kind": "gate" }
      ],
      "icon": "gameplay"
    },
    {
      "id": "visual_spec",
      "label": "Visual Spec",
      "weight": 1.0,
      "signals": [
        { "id": "L0_zone_visuals_contract", "weight": 0.35, "kind": "gate" },
        { "id": "L0_zone_composition", "weight": 0.25, "kind": "gate" },
        { "id": "zone_palette_rows", "weight": 0.2, "kind": "metric", "target": 7 },
        { "id": "impl_shaders_partial", "weight": 0.2, "kind": "spec_status_cap", "cap": 8.5 }
      ],
      "icon": "visual"
    },
    {
      "id": "ux_controls",
      "label": "UX & Controls",
      "weight": 1.0,
      "signals": [
        { "id": "settings_accessibility_doc", "weight": 0.4, "kind": "file_exists", "path": "docs/ui/SETTINGS_ACCESSIBILITY.md" },
        { "id": "combat_presentation_doc", "weight": 0.3, "kind": "file_exists", "path": "docs/art/COMBAT_PRESENTATION.md" },
        { "id": "impl_scenes_not_started", "weight": 0.3, "kind": "spec_status_cap", "cap": 6.5 }
      ],
      "icon": "ux"
    },
    {
      "id": "pm_workflow",
      "label": "PM Workflow",
      "weight": 1.0,
      "signals": [
        { "id": "ci_pass_rate", "weight": 0.25, "kind": "ci_rate" },
        { "id": "L0_doc_sync", "weight": 0.1, "kind": "gate" },
        { "id": "L0_pm_orchestrator", "weight": 0.1, "kind": "gate" },
        { "id": "L0_stakeholder_report", "weight": 0.08, "kind": "gate" },
        { "id": "L0_workflow_integration", "weight": 0.12, "kind": "gate" },
        { "id": "L0_candidate_tournament", "weight": 0.08, "kind": "gate" },
        { "id": "L0_agent_session_telemetry", "weight": 0.12, "kind": "gate" },
        { "id": "L0_factory_watchdog", "weight": 0.1, "kind": "gate" },
        { "id": "L0_sprint_board", "weight": 0.05, "kind": "gate" }
      ],
      "icon": "pm"
    },
    {
      "id": "runtime_proof",
      "label": "Runtime Proof",
      "weight": 1.0,
      "signals": [
        { "id": "has_project_godot", "weight": 0.25, "kind": "branch_impl" },
        { "id": "L2_boot_headless", "weight": 0.35, "kind": "gate_optional" },
        { "id": "L4_integration", "weight": 0.2, "kind": "gate_optional" },
        { "id": "L5_e2e_three_endings", "weight": 0.2, "kind": "gate_optional" }
      ],
      "icon": "runtime"
    },
    {
      "id": "steam_ship",
      "label": "Steam Ship (M6)",
      "weight": 1.0,
      "signals": [
        { "id": "L0_ship_build_security", "weight": 0.25, "kind": "gate" },
        { "id": "L0_player_build_protection", "weight": 0.25, "kind": "gate" },
        { "id": "M5_asset_compliance", "weight": 0.2, "kind": "gate" },
        { "id": "runtime_proof", "weight": 0.3, "kind": "domain_ref" }
      ],
      "icon": "steam"
    }
  ],
  "stale_string_patterns": [
    { "id": "kappa_naming", "pattern": "Kappa-turtle|kappa-turtle", "severity": "doc_nit", "message": "Use spirit-turtle in player-facing copy" },
    { "id": "you_chose_her", "pattern": "You chose her", "severity": "blocking", "message": "Remove invalid emotional beat from dialogue" },
    { "id": "premature_ported", "pattern": "\"port_status\":\\s*\"ported\"", "severity": "blocking", "message": "Helpers must stay pending until PM dispatch" }
  ],
  "recommendation_rules": [
    {
      "id": "REC_CI_FAIL",
      "priority": "P0",
      "category": "blocking",
      "when": "ci_fail_count_gt",
      "value": 0,
      "title": "Fix failing CI gates",
      "action": "Run bash tools/run_docs_ci_checks.sh (main) or bash tools/run_ci_checks.sh (game/development); fix each FAIL gate before merge."
    },
    {
      "id": "REC_PARITY",
      "priority": "P0",
      "category": "blocking",
      "when": "parity_fail",
      "title": "Repair registry ↔ data parity",
      "action": "Align scene_registry.json, story_encounters.json, cinematic_hooks.json, and sprint_board.json ↔ sprint pack IDs; re-run python3 tools/validate_scene_registry.py and python3 tools/validate_sprint_board.py --strict."
    },
    {
      "id": "REC_STALE_BLOCKING",
      "priority": "P0",
      "category": "blocking",
      "when": "stale_blocking",
      "title": "Remove blocking stale strings",
      "action": "Grep repo for patterns in alignment_audit_catalog stale_string_patterns; fix data and docs."
    },
    {
      "id": "REC_SPEC_DEV_START",
      "priority": "P1",
      "category": "before_dispatch",
      "when": "branch_is",
      "value": "main",
      "title": "P1-00 bootstrap restored — dispatch Phase 1 implementation",
      "action": "game/project.godot + boot + unit tests are on game/development. Next: Architect/Builder pick up P1-01+ (zone palettes, shaders, scenes via GDAI). Keep L0_game_branch_bootstrap green."
    },
    {
      "id": "REC_RUNTIME_LOW",
      "priority": "P1",
      "category": "implementation",
      "when": "domain_score_lt_on_branch",
      "domain": "runtime_proof",
      "branch": "game/development",
      "value": 5.0,
      "title": "Raise Runtime Proof via P1-00 bootstrap",
      "action": "GDAI MCP: project.godot, boot_loader.gd, F5 smoke; target L2_boot_headless PASS on game/development."
    },
    {
      "id": "REC_VISUAL_SLICE",
      "priority": "P1",
      "category": "implementation",
      "when": "branch_is",
      "value": "game/development",
      "title": "Ruined village vertical slice",
      "action": "GDAI MCP build ruined_village.tscn; run bash tools/run_visual_smoke_checks.sh; cite L2_visual_palette."
    },
    {
      "id": "REC_L5_E2E",
      "priority": "P2",
      "category": "ship_path",
      "when": "domain_score_lt",
      "domain": "steam_ship",
      "value": 6.0,
      "title": "L5 three-endings E2E before human QA",
      "action": "bash tools/run_e2e_playthrough.sh on game/development; all SC-17a/b/c paths must PASS."
    },
    {
      "id": "REC_STAKEHOLDER_VISUALS",
      "priority": "P2",
      "category": "stakeholder",
      "when": "visuals_missing",
      "min_present": 30,
      "title": "Refresh stakeholder visual pack",
      "action": "Copy PNGs to docs/compliance/alignment_audit_visuals/ then: bash tools/run_alignment_audit.sh --visuals-from docs/compliance/alignment_audit_visuals"
    },
    {
      "id": "REC_WORKFLOW_DRIFT",
      "priority": "P0",
      "category": "blocking",
      "when": "gate_fail",
      "gate": "L0_workflow_integration",
      "title": "Factory workflow integration drift",
      "action": "Run python3 tools/validate_workflow_integration.py; update game/data/qa/workflow_integration_registry.json and wire missing hooks/docs per docs/qa/WORKFLOW_INTEGRATION.md."
    },
    {
      "id": "REC_AGENT_TELEMETRY",
      "priority": "P0",
      "category": "blocking",
      "when": "gate_fail",
      "gate": "L0_agent_session_telemetry",
      "title": "Agent session telemetry schema drift",
      "action": "Run python3 tools/validate_agent_session_telemetry.py; wire hooks in session gate, cycle events, orchestrator, and watchdog per docs/qa/AGENT_SESSION_TELEMETRY.md. Requires CURSOR_API_KEY secret."
    },
    {
      "id": "REC_FACTORY_WATCHDOG",
      "priority": "P0",
      "category": "blocking",
      "when": "gate_fail",
      "gate": "L0_factory_watchdog",
      "title": "Factory watchdog config drift",
      "action": "Run python3 tools/validate_factory_watchdog.py; verify tools/run_factory_watchdog.sh hooks and docs/agents/FACTORY_WATCHDOG.md. Requires CURSOR_FACTORY_ALERT_WEBHOOK_URL secret."
    },
    {
      "id": "REC_DOC_NITS",
      "priority": "P3",
      "category": "doc_nit",
      "when": "stale_doc_nit",
      "title": "Sweep cosmetic doc drift",
      "action": "Fix stale_string_patterns doc_nit hits; keep LEVEL_DESIGN.md in sync with scene_registry.json."
    }
  ],
