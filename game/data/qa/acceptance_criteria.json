  "ci_gates": {
    "branch": "game/development",
    "workflow": ".github/workflows/game-ci.yml",
    "runner": "bash tools/run_ci_checks.sh",
    "required_gates": [
      "L0_rr_compliance",
      "L0_no_secrets",
      "L0_ship_build_security",
      "L0_player_build_protection",
      "L0_difficulty_data",
      "L0_story_data",
      "L0_narrative_density",
      "L0_acceptance_catalog",
      "L0_base_classes",
      "L1_unit_tests",
      "L1_gdscript_lint",
      "L0_base_class_compliance",
      "L2_scene_primitives",
      "L3_gdai_built",
      "L2_animation_whitelist",
      "L2_feel_smoke",
      "L2_perf_catalog",
      "L2_linux_export_smoke",
      "L2_windows_cross_export",
      "L2_glb_import",
      "L4_integration",
      "M5_asset_compliance"
    ],
    "conditional_gates": [
      {
        "gate_id": "L2_boot_headless",
        "skip_when": "no run/main_scene in project.godot",
        "skip_is_not_ship_pass": true
      },
      {
        "gate_id": "L2_linux_export_smoke",
        "skip_when": "no game/project.godot OR phase_1 bootstrap (no main_scene)",
        "skip_is_not_ship_pass": true
      },
      {
        "gate_id": "L2_windows_cross_export",
        "skip_when": "no game/project.godot OR phase_1 bootstrap (no main_scene)",
        "skip_is_not_ship_pass": true
      },
      {
        "gate_id": "L1_gdscript_lint",
        "skip_when": "phase_1 bootstrap and no .gd files in diff",
        "skip_is_not_ship_pass": true,
        "bootstrap_only": true
      },
      {
        "gate_id": "L2_glb_import",
        "skip_when": "phase_1 bootstrap — no hero GLBs until M5",
        "skip_is_not_ship_pass": true,
        "bootstrap_only": true
      },
      {
        "gate_id": "L2_animation_whitelist",
        "skip_when": "phase_1 bootstrap — phase 1 catalog, no rigged GLBs on disk",
        "skip_is_not_ship_pass": true,
        "bootstrap_only": true
      }
    ],
    "excluded_gates": [
      "check_mcp_ready",
      "L3_gdai_f5",
      "L3_perf_review",
      "L2_windows_export_run",
      "L2_visual_jury",
      "L2_model_jury",
      "L2_audio_jury",
      "L2_vo_jury",
      "L5_e2e_three_endings",
      "L6_human_playtest"
    ],
    "design_ref": "docs/ci-cd/CI.md, .cursorrules §0, docs/workflow/AI_DEV_WORKFLOW.md §2",
    "merge_policy": "game/development PRs require CI green. P1-00 may use bash tools/run_bootstrap_ci_checks.sh until main_scene is set; full run_ci_checks.sh required after P1-02."
  },
  "issue_bootstrap": {
    "P1-00": {
      "title": "Bootstrap game/development — project.godot + CI baseline",
      "runner": "bash tools/run_bootstrap_ci_checks.sh",
      "required_gate_ids": [
        "L0_rr_compliance",
        "L0_story_data",
        "L0_narrative_density",
        "L0_acceptance_catalog",
        "L0_base_classes",
        "L1_unit_tests"
      ],
      "deferred_gate_ids": [
        "L1_gdscript_lint",
        "L2_glb_import",
        "L2_animation_whitelist",
        "L2_linux_export_smoke",
        "L2_windows_cross_export",
        "L2_windows_export_run",
        "L2_boot_headless",
        "L4_integration"
      ],
      "deferred_until": "P1-02 merged (main_scene + GDAI ruined_village) or phase_1 exit",
      "design_ref": "docs/sprints/Phase1-Sprint1-issues.md §P1-00"
    }
  },
  "toolchain_requirements": {
    "required_not_optional": [
      {
        "id": "gamelab_mcp",
        "check": "gamelab-mcp in Cursor + GAMELAB_API_KEY",
        "command": "bash tools/check_extended_toolchain.sh",
        "asset_fallback": "Procedural UI placeholders OK for asset output until GameLab gen ships"
      },
      {
        "id": "blender",
        "check": "blender in PATH",
        "purpose": "M5 turntable QA — docs/art/MODEL_QA.md M3",
