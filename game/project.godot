; Engine configuration file.
; Tides of Urashima — fresh implementation (docs on main are source of truth)
; Godot 4.3+ Forward+

config_version=5

[application]

config/name="Tides of Urashima"
config/description="A short stylized 3D JRPG adapted from Japanese folklore."
config/version="0.1.0-dev"
run/main_scene="res://scenes/boot.tscn"
config/features=PackedStringArray("4.3", "Forward Plus")
config/icon="res://assets/ui/icon.svg"

[autoload]

GameBootstrap="*res://scripts/core/game_bootstrap.gd"

[display]

window/size/viewport_width=1920
window/size/viewport_height=1080
window/stretch/mode="canvas_items"
window/stretch/aspect="expand"

[internationalization]

locale/fallback="en"

[rendering]

renderer/rendering_method="forward_plus"
textures/vram_compression/import_etc2_astc=true
anti_aliasing/quality/msaa_3d=2
