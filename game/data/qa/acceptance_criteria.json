{
  "version": "1.1",
  "authority": "Source of truth for measurable QA pass/fail. If a check is not listed here with a threshold, it cannot block ship.",
  "global_rules": {
    "warn_is_not_pass": true,
    "skip_is_not_pass": true,
    "exit_zero_with_warn_is_not_ship_pass": true,
    "jury_min_pass_models": 2,
    "jury_min_active_models": 2,
    "jury_min_confidence": 0.65,
    "remediation_required_on_fail": true,
    "evidence_required_for_pass": true,
    "agent_must_cite_criterion_id": true
  },
  "invalid_pass_patterns": [
    "F5 runs with 0 errors but no screenshot",
    "Jury skipped (no API keys) counted as PASS",
    "WARN-only technical lint counted as PASS for M5 ship",
    "overall_pass true with confidence below jury_min_confidence",
    "overall_pass true when any criterion boolean is false",
    "Re-running jury without rebuilding asset",
    "Lowering min_pass or thresholds to force green",
    "Marking phase complete with E2E script SKIP",
    "Claiming visual PASS without artifacts/screenshots evidence",
    "Procedural placeholder audio/model marked ship-ready",
    "Hand-edited ship .tscn merged without game/scenes/.gdai_built marker",
    "Treating GameLab MCP or Blender as optional for ship",
    "Merging game/development PR without green CI",
    "Skipping L6 human playtest for ship",
    "PM session without run_pm_orchestrator.sh PASS",
    "Agent work without run_agent_session_gate.sh PASS",
    "GitHub issue closed but sprint_board status not done",
    "Sprint issue pack and sprint_board ID mismatch",
    "Skipping run_post_agent_cycle.sh after issue done (factory stall)",
    "Calling pm_emit_cycle_event.sh directly instead of run_post_agent_cycle.sh (honor system)",
    "Ignoring factory_halt flag and starting workers anyway",
    "Marking issue done without pm_check_done_criteria PASS",
    "Architect and Builder work in same agent session (strict role violation)",
    "Skipping evidence bundle before issue done",
    "Cycle complete without stakeholder report (pm_emit_stakeholder_report)",
    "Scene/visual PR merged without L3_perf_review evidence when scenes or shaders changed",
    "Bug fix touching scenes/shaders merged without perf re-check in affected zone",
    "L3_perf_review PASS without baseline_id reference_linux_cloud or reference_pc_gtx1060",
    "FPS ship sign-off from cloud_agent_jit or ci_headless baseline",
    "Windows-only ship claim while primary dev runs on Linux cloud (see PLATFORM_SUPPORT.md)",
    "Ship export without export_strip_dev_plugins_begin (dev MCP/GDAI in build)",
    "Tracked file contains live API key or webhook URL (L0_no_secrets FAIL)",
    "Cross-cutting factory feature merged without workflow_integration_registry.json entry",
    "Factory feature registry drift — L0_workflow_integration FAIL after hook or doc change"
  ],
  "gates": {
