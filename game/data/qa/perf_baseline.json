    "steam_minimum": {
      "label": "Steam store minimum — support floor only",
      "valid_for_l3_perf_review": false,
      "valid_for_ship_signoff": false,
      "platform": "windows",
      "os": { "name": "Windows", "version_min": "10 64-bit" },
      "cpu": {
        "class": "dual-core",
