        "channels": { "op": "in", "value": [1, 2] },
        "bgm_lufs": { "op": "within", "target": -16.0, "tolerance": 4.0 },
        "bgm_true_peak_dbtp": { "op": "<=", "value": -1.0 },
        "voice_lufs": { "op": "within", "target": -18.0, "tolerance": 4.0 },
        "amb_lufs": { "op": "within", "target": -22.0, "tolerance": 4.0 }
      },
      "ship_extra": { "procedural_placeholder_banned": true },
      "evidence": ["game/assets/audio/**/*.ogg"],
      "design_ref": "docs/audio/AUDIO_QA.md §A2"
    },
    "L2_vo_technical": {
      "layer": "L2",
      "domain": "audio",
      "command": "python3 tools/check_audio_vo.py",
      "description": "P0 VO duration, loudness, locale paths vs dialogue script",
      "metrics": {
        "max_duration_sec": { "op": "<=", "from": "audio_qa_catalog.vo_clips.*.max_duration_sec" },
        "voice_lufs": { "op": "within", "target": -18.0, "tolerance": 4.0 },
        "voice_true_peak_dbtp": { "op": "<=", "value": -3.0 }
      },
      "ship_extra": { "all_p0_locales_required": true },
      "evidence": ["game/assets/audio/voice/**/*.ogg"],
      "design_ref": "docs/audio/AUDIO_QA.md §A4"
    },
    "L2_audio_catalog": {
      "layer": "L2",
      "domain": "audio",
      "command": "python3 tools/check_audio_catalog.py --phase {phase}",
      "description": "All BGM/SFX tracks required for the phase are present in the audio catalog",
      "pass": { "missing_tracks": 0 },
      "design_ref": "docs/audio/AUDIO_QA.md §A1"
    },
    "L3_gdai_built": {
      "layer": "L3",
      "domain": "flow",
      "command": "bash tools/check_l3_gdai_built.sh",
      "description": "When ship scenes or main_scene change in diff, game/scenes/.gdai_built must update with verified_f5=true",
      "pass": { "exit_code": 0 },
      "skip_when": "no ship scene or main_scene changes in diff",
      "evidence": ["game/scenes/.gdai_built"],
      "design_ref": "docs/ci-cd/CI.md, docs/cheat-sheets/CONTROLS_CHEATSHEET.md, game/scenes/README.md"
    },
    "L3_gdai_f5": {
      "layer": "L3",
      "domain": "flow",
      "command": "GDAI MCP F5 playtest in Godot editor",
      "description": "Full viewport verify — agent-local; not GitHub Actions",
      "pass": { "verified_f5": true, "editor_errors": 0 },
      "evidence": ["game/scenes/.gdai_built"],
      "design_ref": "docs/agents/MCP_STACK.md, .cursorrules §0"
    },
    "L3_perf_review": {
      "layer": "L3",
      "domain": "flow",
      "command": "Godotiq godotiq_perf_snapshot after F5 in affected zone",
      "description": "Lightweight performance review — FPS, draw calls, node count; not a code review",
      "pass": {
        "min_fps": 55,
        "max_materials_per_view": 8,
        "draw_calls_investigate_above": 1000
      },
      "skip_when": "no game/project.godot or docs/data-only PR",
      "evidence": ["artifacts/perf_reviews/<zone>_<commit>.json"],
      "design_ref": "docs/qa/PERFORMANCE_BASELINE.md, docs/qa/PLATFORM_SUPPORT.md, game/data/qa/perf_baseline.json, game/data/qa/perf_thresholds.json"
    },
    "L4_integration": {
      "layer": "L4",
      "domain": "flow",
      "command": "bash tools/run_integration_tests.sh",
      "description": "Integration/flow scenarios (INT-*) all pass — no failing scenarios",
      "pass": { "exit_code": 0, "failed_scenarios": 0 },
      "evidence": ["game/tests/integration/"],
      "design_ref": "docs/qa/AI_TESTING_SPEC.md §6"
    },
    "L5_e2e_three_endings": {
      "layer": "L5",
      "domain": "flow",
      "command": "REQUIRE_L5=1 bash tools/run_e2e_playthrough.sh",
      "description": "End-to-end playthrough reaches all three endings (rewind/anchor/drift); SKIP not allowed",
      "pass": { "exit_code": 0, "skip_allowed": false, "endings_passed": ["rewind", "anchor", "drift"] },
      "evidence": ["artifacts/videos/e2e_*.mp4"],
      "design_ref": "docs/qa/AI_TESTING_SPEC.md §7"
    },
    "L6_human_playtest": {
      "layer": "L6",
      "domain": "flow",
      "command": "docs/qa/PLAYTEST_SCRIPT.md",
      "description": "Human playtest sign-off — ≥80% completion, zero open S0/S1 bugs, ≥5 testers (only after L0–L5 pass)",
      "pass": { "completion_percent": 80, "s0_s1_open": 0, "min_testers": 5 },
      "prerequisite": ["L0", "L1", "L2", "L3", "L4", "L5"],
      "design_ref": "docs/qa/PLAYTEST_SCRIPT.md"
    },
    "L0_doc_sync": {
      "layer": "L0",
      "domain": "flow",
      "command": "python3 tools/check_doc_sync.py",
      "description": "Docs stay in sync — every top-level doc is indexed in README, links resolve, and runner gates match the acceptance catalog",
      "pass": { "exit_code": 0 },
      "evidence": ["docs/README.md"],
      "design_ref": "docs/README.md, docs/workflow/BRANCHING.md"
    },
    "L0_alignment_audit_catalog": {
      "layer": "L0",
      "domain": "flow",
      "command": "python3 tools/validate_alignment_audit_catalog.py",
      "description": "Alignment audit catalog, runner, and recommendation rules for standard stakeholder audits",
      "pass": { "exit_code": 0 },
      "evidence": ["game/data/qa/alignment_audit_catalog.json", "docs/qa/ALIGNMENT_AUDIT.md"],
      "design_ref": "docs/qa/ALIGNMENT_AUDIT.md"
    },
    "L0_workflow_integration": {
      "layer": "L0",
      "domain": "flow",
      "command": "python3 tools/validate_workflow_integration.py",
      "description": "Factory workflow integration registry — script hooks, doc cross-refs, secrets parity for cross-cutting features",
      "pass": { "exit_code": 0 },
      "evidence": ["game/data/qa/workflow_integration_registry.json", "docs/qa/WORKFLOW_INTEGRATION.md"],
      "design_ref": "docs/qa/WORKFLOW_INTEGRATION.md"
    },
    "M5_asset_compliance": {
      "layer": "ship",
      "domain": "compliance",
      "command": "bash tools/check_asset_compliance.sh",
      "description": "Every shipped media asset is covered by the license manifest (copyright-safe)",
      "pass": { "exit_code": 0 },
      "design_ref": "docs/art/ASSET_COMPLIANCE.md"
    }
  },
  "jury": {
    "visual": {
      "gate_id": "L2_visual_jury",
      "min_pass_models": 2,
      "min_active_models": 2,
      "min_confidence": 0.65,
      "require_issues_on_fail": true,
      "criteria": {
        "v1_primitives_visible": { "expect": false, "label": "No obvious axis-aligned box primitives" },
        "v2_muted_palette": { "expect": true, "label": "Muted coastal palette" },
        "v3_npr_not_pbr": { "expect": true, "label": "Stylized NPR not glossy PBR" },
        "v4_japanese_coastal": { "expect": true, "label": "Japanese coastal motifs" },
        "v5_silhouette_readable": { "expect": true, "label": "Readable silhouettes" },
        "v6_ui_clean": { "expect": true, "label": "UI clean if visible" },
        "v7_emotional_mood_matches": { "expect": true, "label": "Zone emotional mood matches brief" },
        "v8_no_forbidden_tone": { "expect": true, "label": "No forbidden tone (comedy/horror gore/bright cheer)" }
      },
      "evidence": ["artifacts/screenshots/*.png", "artifacts/visual_reviews/*.jury.json"],
      "design_ref": "docs/art/VISUAL_QA.md §2G"
    },
    "model": {
      "gate_id": "L2_model_jury",
      "min_pass_models": 2,
      "min_active_models": 2,
      "min_confidence": 0.65,
      "require_issues_on_fail": true,
      "criteria": {
        "m1_not_block_primitive": { "expect": true, "label": "Not block primitive" },
        "m2_japanese_coastal_style": { "expect": true, "label": "Japanese coastal style" },
        "m3_adult_not_chibi": { "expect": true, "label": "Adult proportions not chibi" },
        "m4_silhouette_readable": { "expect": true, "label": "Silhouette readable" },
        "m5_sufficient_detail": { "expect": true, "label": "Sufficient NPR detail" },
        "m6_matches_brief": { "expect": true, "label": "Matches CHARACTER_BIBLE brief" },
        "m7_emotional_mood_matches": { "expect": true, "label": "Emotional mood matches generation brief" },
        "m8_no_forbidden_tone": { "expect": true, "label": "No forbidden tone (comedy/horror gore/bright cheer)" }
      },
      "evidence": ["artifacts/model_reviews/*/front.png", "artifacts/model_reviews/*.model_jury.json"],
      "design_ref": "docs/art/MODEL_QA.md §M3b"
    },
    "audio": {
      "gate_id": "L2_audio_jury",
      "min_pass_models": 2,
      "min_active_models": 2,
      "min_confidence": 0.65,
      "require_issues_on_fail": true,
      "hero_tracks_only": true,
      "criteria": {
        "a1_not_cheap_procedural": { "expect": true, "label": "Not cheap procedural placeholder" },
        "a2_melancholy_coastal": { "expect": true, "label": "Melancholy coastal mood" },
        "a3_not_upbeat_pop": { "expect": true, "label": "Not upbeat pop/EDM" },
        "a4_instrumental_no_vocals": { "expect": true, "label": "Instrumental no vocals" },
        "a5_fits_scene_mood": { "expect": true, "label": "Fits scene mood" },
        "a6_emotional_mood_matches": { "expect": true, "label": "Emotional mood matches generation brief" },
        "a7_no_forbidden_tone": { "expect": true, "label": "No forbidden tone (comedy/horror gore/bright cheer/EDM)" }
      },
      "evidence": ["artifacts/audio_reviews/*.jury.json"],
      "design_ref": "docs/audio/AUDIO_QA.md §A3"
    },
    "vo": {
      "gate_id": "L2_vo_jury",
      "min_pass_models": 2,
      "min_active_models": 2,
      "min_confidence": 0.65,
      "require_issues_on_fail": true,
      "p0_clips_only": true,
      "gate_locale": "en",
      "criteria": {
        "v1_not_robotic_placeholder": { "expect": true, "label": "Not robotic TTS placeholder" },
        "v2_script_semantics_match": { "expect": true, "label": "Script semantics match dialogue" },
        "v3_matches_direction": { "expect": true, "label": "Matches vo_prompts direction" },
        "v4_not_anime_exaggeration": { "expect": true, "label": "Not anime exaggeration" },
        "v5_fits_scene_mood": { "expect": true, "label": "Fits scene mood" },
        "v6_emotional_mood_matches": { "expect": true, "label": "Emotional mood matches generation brief" },
        "v7_no_forbidden_tone": { "expect": true, "label": "No forbidden tone from brief" }
      },
      "evidence": ["artifacts/vo_reviews/*.jury.json"],
      "design_ref": "docs/audio/AUDIO_QA.md §A5"
    }
  },
