{
  "mcpServers": {
    "godot-mcp": {
      "command": "uv",
      "args": [
        "/ABSOLUTE/PATH/TO/game/addons/gdai-mcp-plugin-godot/gdai_mcp_server.py"
      ]
    },
    "godotiq": {
      "command": "uvx",
      "args": ["godotiq"],
      "env": {
        "GODOTIQ_PROJECT_ROOT": "/ABSOLUTE/PATH/TO/game"
      }
    },
    "godot-mcp-pro": {
      "command": "node",
      "args": [
        "/ABSOLUTE/PATH/TO/tools/godot-mcp-pro-server/build/index.js",
        "--minimal"
      ],
      "env": {
        "GODOT_MCP_PORT": "6505"
      }
    }
  },
  "_optional_extended_stack": {
    "_comment": "See docs/MCP_EXTENDED_STACK.md — merge gamelab-mcp into mcpServers when API key is set",
    "gamelab-mcp": {
      "type": "sse",
      "url": "http://api.gamelabstudio.co:8765/sse",
      "headers": {
        "X-API-Key": "YOUR_GAMELAB_API_KEY"
      }
    }
  }
}
