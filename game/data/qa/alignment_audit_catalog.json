{
  "version": "1.3",
  "authority": "docs/qa/ALIGNMENT_AUDIT.md",
  "description": "Standard alignment audit domains, scoring signals, recommendation rules, and stakeholder visual packs.",
  "outputs": {
    "artifacts_dir": "artifacts/alignment_audits",
    "committed_reports_dir": "docs/compliance/alignment_audit_reports",
    "shared_visuals_dir": "docs/compliance/alignment_audit_visuals",
    "history_index": "docs/compliance/alignment_audit_history.json",
    "latest_json": "artifacts/alignment_audits/latest.json",
    "latest_markdown": "artifacts/alignment_audits/latest.md",
    "latest_html": "artifacts/alignment_dashboard.html",
    "visuals_subdir": "visuals",
    "history_keep": 100,
    "committed_history_keep": 50,
    "archive_visual_snapshots": false
  },
  "visual_policy": {
    "generator_script": "tools/generate_audit_radar_images.py",
