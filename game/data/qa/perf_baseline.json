    },
    "ci_headless": {
      "label": "GitHub Actions / headless Godot",
      "valid_for_l3_perf_review": false,
      "valid_for_ship_signoff": false,
      "platform": "linux",
      "notes": "Boot and integration only. No FPS measurement."
    }
  },
  "evidence_schema": {
    "path_pattern": "artifacts/perf_reviews/{zone}_{short_sha}.json",
    "required_fields": [
      "baseline_id",
      "commit_sha",
      "zone_id",
      "captured_at",
      "resolution",
      "graphics_quality",
      "vsync",
      "fps_avg",
      "fps_min",
      "draw_calls",
      "node_count",
      "materials_visible",
      "tool"
    ],
    "optional_fields": [
      "gpu_name",
      "cpu_name",
      "ram_gb",
      "vram_gb",
      "godot_version",
      "editor_vs_export",
      "notes"
    ],
    "tool_expected": "godotiq_perf_snapshot"
  },
